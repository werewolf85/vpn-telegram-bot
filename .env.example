# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Admin user ID (можно несколько через запятую)
ADMIN_TELEGRAM_IDS=820780825

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vpn_bot
DB_USER=vpn_user
DB_PASSWORD=your_secure_password

# Xray
XRAY_CONFIG_PATH=/etc/xray/config.json
XRAY_API_ADDR=127.0.0.1:10085  # Xray API порт (если включён)
XRAY_RESTRICTED_PORT=10086       # Порт для restricted API (опционально)

# CryptoBot (USDT payments)
CRYPTOBOT_TOKEN=your_cryptobot_token
# Минимальная сумма пополнения (в USDT)
MIN_DEPOSIT_USDT=1.0

# Servers config
SERVERS_JSON_PATH=./config/servers.json

# Traffic limits (GB)
DEFAULT_TRAFFIC_LIMIT_GB=100
DEFAULT_EXPIRY_DAYS=30

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/vpn-bot.log

# Node env
NODE_ENV=development
