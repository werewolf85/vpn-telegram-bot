# ============================================
# PROXYGATE VPN TELEGRAM BOT — ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ
# ============================================
# Скопируйте этот файл в .env и заполните значения
# Никогда не коммитьте .env в Git!

# --------------------------------------------
# TELEGRAM BOT (Обязательно)
# --------------------------------------------
TELEGRAM_BOT_TOKEN=ваш_токен_бота_от_BotFather
# Как получить: @BotFather → /newbot → скопировать токен (формат: 123456:ABC...)

ADMIN_TELEGRAM_IDS=820780825
# ID администраторов (несколько через запятую). Как получить: @userinfobot → ваш ID

# --------------------------------------------
# DATABASE — PostgreSQL (Обязательно)
# --------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vpn_bot
DB_USER=postgres
DB_PASSWORD=ваш_пароль_от_postgres

# Варианты развёртывания БД:
# - Локально: brew/apt-get install postgresql
# - Docker: docker run -e POSTGRES_PASSWORD=secret -p 5432:5432 -d postgres:15
# - Облако: Supabase, Neon, RDS (получите connection string)

# --------------------------------------------
# PAYMENTS — CryptoBot (USDT) (Опционально)
# --------------------------------------------
CRYPTOBOT_TOKEN=ваш_токен_от_CryptoBot
# Как получить: @CryptoBot → /start → 👛 Кошелёк → 📥 Receive → 🔗 Generate Payment Link → Token
# Или: @BotFather → выбрать @CryptoBot → API Tokens → Copy Token

MIN_DEPOSIT_USDT=1.0
# Минимальная сумма пополнения в USDT

# --------------------------------------------
# PAYMENTS — ЮKassa (RUB) (Опционально)
# --------------------------------------------
YOOMONEY_SHOP_ID=ваш_shop_id_от_ЮKassa
# Как получить: yookassa.ru → Настройки магазина → Интеграция → API → Shop ID

YOOMONEY_SECRET=ваш_секретный_ключ_от_ЮKassa
# Как получить: yookassa.ru → Настройки магазина → Интеграция → API → Создать API-ключ

MIN_DEPOSIT_RUB=100.0
# Минимальная сумма пополнения в RUB

# --------------------------------------------
# XRAY (Опционально, для работы с прокси)
# --------------------------------------------
XRAY_CONFIG_PATH=/etc/xray/config.json
# Путь к конфигурационному файлу Xray на сервере
# По умолчанию, если установлен через скрипт: /etc/xray/config.json

# --------------------------------------------
# SERVER & LOGGING
# --------------------------------------------
PORT=3000
# Порт Express сервера (production: 8080, или 80/443 через nginx)

NODE_ENV=development
# Режим: development (с отладкой) или production

LOG_LEVEL=info
# Уровень логирования: debug, info, warn, error

LOG_FILE=./logs/vpn-bot.log
# Путь к файлу логов (автоматически создаётся)

# --------------------------------------------
# OPTIONAL
# --------------------------------------------
SERVERS_JSON_PATH=./config/servers.json
# Путь к JSON с конфигурацией серверов (если не в БД)

DEFAULT_TRAFFIC_LIMIT_GB=100
# Лимит трафика по умолчанию (в гигабайтах) для новых аккаунтов

DEFAULT_EXPIRY_DAYS=30
# Срок действия аккаунта по умолчанию (дней)

# --------------------------------------------
# EXAMPLE VALUES (ЗАМЕНИТЕ НА РЕАЛЬНЫЕ!)
# --------------------------------------------
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz-1234567890
# ADMIN_TELEGRAM_IDS=820780825
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=vpn_bot
# DB_USER=postgres
# DB_PASSWORD=secret_password
# CRYPTOBOT_TOKEN=123456:ABCdefGHIjklMNOpqrsTUVwxyz-1234567890
# YOOMONEY_SHOP_ID=123456
# YOOMONEY_SECRET=test_ABCD1234567890abcdefghijklmnopqrstuvwxyz
